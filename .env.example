# LetsWatch deployment configuration.
#
# Easiest path: run `./setup.sh`. It asks only for the values that are yours
# (media path, license id, activation secret, admin login) and auto-generates
# every random secret below. Editing this file by hand is optional.
#
# Manual path: copy to .env and fill every empty value before
# `docker compose up -d`.
# NOTE: license verifier key, mTLS activation credential and build seeds are
# already baked into the published image — you do NOT configure them here.

# ---------------------------------------------------------------------------
# Image tags. Pin to a released version in production instead of `latest`.
# ---------------------------------------------------------------------------
LETSWATCH_IMAGE_TAG=latest
LETSWATCH_FRONTEND_IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Media library (MoviePilot-organized). Absolute host path, mounted read-only.
# For an rclone Google Drive mount, set SCAN_SOURCE=rclone-gdrive.
# Example: /storage/media
# ---------------------------------------------------------------------------
LETSWATCH_MEDIA_PATH=
LETSWATCH_SCAN_SOURCE=local
LETSWATCH_RCLONE_REMOTE=
LETSWATCH_RCLONE_BINARY=rclone
LETSWATCH_RCLONE_CHECKERS=8
LETSWATCH_RCLONE_LIST_TIMEOUT=30m
LETSWATCH_RCLONE_SKIP_NFO=false
LETSWATCH_SCAN_WORKERS=4

# ---------------------------------------------------------------------------
# Published ports.
#   HTTP_PORT  -> clients connect to http://<server-ip>:<port>/emby
#   ADMIN_PORT -> admin web UI
# ---------------------------------------------------------------------------
LETSWATCH_HTTP_PORT=18081
LETSWATCH_ADMIN_PORT=18082

# ---------------------------------------------------------------------------
# PostgreSQL.
# ---------------------------------------------------------------------------
LETSWATCH_POSTGRES_DB=letswatch
LETSWATCH_POSTGRES_USER=letswatch
LETSWATCH_POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Initial administrator account (created when the database is empty).
# Default username is "admin" if left empty.
# ---------------------------------------------------------------------------
LETSWATCH_USERNAME=
LETSWATCH_PASSWORD=

# ---------------------------------------------------------------------------
# Service + streaming secrets. `setup.sh` fills these automatically. To do it
# by hand, generate a strong random value for each, e.g.:
#   openssl rand -base64 32
# ---------------------------------------------------------------------------
LETSWATCH_INTERNAL_TOKEN=
LETSWATCH_STREAM_TOKEN_SECRET=
LETSWATCH_STREAM_TOKEN_TTL=6h
LETSWATCH_REQUIRE_STREAM_TOKEN=true
# Usually empty. Set only if PlaybackInfo must return an absolute external origin.
LETSWATCH_STREAM_BASE_URL=

# ---------------------------------------------------------------------------
# License. Use the id and activation secret issued to you. Activation is online
# and binds to this host's machine-id.
# ---------------------------------------------------------------------------
LETSWATCH_LICENSE_ID=
LETSWATCH_LICENSE_ACTIVATION_SECRET=

# ---------------------------------------------------------------------------
# Admin frontend.
# ---------------------------------------------------------------------------
# Leave the default to reach the API over the internal compose network.
LETSWATCH_FRONTEND_UPSTREAM=http://letswatch:8080
# Random session secret. `setup.sh` fills this; or `openssl rand -base64 32`.
LETSWATCH_FRONTEND_SESSION_SECRET=
LETSWATCH_FRONTEND_SESSION_TTL=28800
LETSWATCH_FRONTEND_ENV_LABEL=

# ---------------------------------------------------------------------------
TZ=Asia/Shanghai
